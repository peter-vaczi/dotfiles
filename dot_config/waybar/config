{
    "layer": "top",
    "position": "top",

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "clock#1",
        "clock#2"
    ],
    
    // "modules-center": [
    //     "sway/window"
    // ],

    "modules-right": [
        "disk",
        "network",
        "custom/vpn",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "pulseaudio",
        "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },
    
    "sway/window": {
        "max-length": 50,
        "tooltip": false
    },
    
    "disk":{
        "path": "/",
        "format": "яВа {free}"
    },

    "cpu": {
        "format": "яЛЫ {usage}%  {avg_frequency}GHz"
    },

    "memory": {
        "format": "яГЙ {percentage}%"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"],
        "on-click": "xsensors"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% яКФ",
        "format-muted": "яЪй",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["яЖЕ", "яДС"]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "яГз {capacity}%",
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },

    "clock#1": {
        //"format": "{:%a %Y %b %d %R}",
        "format": "яБ│ {:%Y.%m.%d}",
        "tooltip": false
    },

    "clock#2": {
        //"format": "{:%a %Y %b %d %R}",
        "format": "яАЧ {:%H:%M}",
        "tooltip": false
    },

    "tray": {
		    "icon-size": 15,
        "spacing": 10
    },

    "network": {
        "interface": "wlan0",
        "format": "{ifname}",
        "format-wifi": "яЗл {essid}",
        "format-ethernet": "яЫ┐ {ipaddr}",
        "format-linked": "яЮЦ",
        "format-disconnected": "тЪа",
        "tooltip-format-wifi": "{ifname} {essid} {ipaddr} ({signalStrength}%) ",
        "tooltip-format-ethernet": "{ifname} {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },

    "custom/vpn": {
        "format": "VPN {icon}",
        "exec": "/home/ptr/bin/vpn-waybar",
        "return-type": "json",
        "on-click": "if [[ -d /proc/sys/net/ipv4/conf/tun0 ]]; then /home/ptr/bin/vpn-off; else /home/ptr/bin/vpn-on; fi",
        "format-icons": ["яПБ", "яАг"],
        "interval": 2
    }
}
