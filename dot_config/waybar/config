{
    "layer": "top",
    "position": "top",

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "clock#1",
        "clock#2"
    ],
    
    // "modules-center": [
    //     "sway/window"
    // ],

    "modules-right": [
        "disk",
        "network",
        "custom/vpn",
        "custom/proxy",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "pulseaudio",
        "backlight",
        "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },
    
    "sway/window": {
        "max-length": 50,
        "tooltip": false
    },
    
    "disk":{
        "path": "/",
        "format": "´éá {free}"
    },

    "cpu": {
        "format": "´őŤ {usage}%"
    },

    "memory": {
        "format": "´âë {percentage}%"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["´Łź", "´őë", "´Łę"],
        "on-click": "xsensors"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% ´Őö",
        "format-muted": "´Üę",
        "format-icons": {
            "headphones": "´Çą",
            "handsfree": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["´ćů", "´äĹ"]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "´âž {capacity}%",
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
        ]
    },

    "clock#1": {
        //"format": "{:%a %Y %b %d %R}",
        "format": "´ü│ {:%Y.%m.%d}",
        "tooltip": false
    },

    "clock#2": {
        //"format": "{:%a %Y %b %d %R}",
        "format": "´ÇŚ {:%H:%M}",
        "tooltip": false
    },

    "tray": {
		    "icon-size": 15,
        "spacing": 10
    },

    "network": {
        "interface": "wlan0",
        "format": "{ifname}",
        "format-wifi": "´çź {essid}",
        "format-ethernet": "´Ť┐",
        "format-linked": "´×ľ",
        "format-disconnected": "ÔÜá",
        "tooltip-format-wifi": "{ifname} {essid} {ipaddr} ({signalStrength}%) ",
        "tooltip-format-ethernet": "{ifname} {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },

    "custom/vpn": {
        "format": "VPN {icon}",
        "exec": "/home/ptr/bin/vpn-waybar",
        "return-type": "json",
        "on-click": "if [[ -d /proc/sys/net/ipv4/conf/tun0 ]]; then /home/ptr/bin/vpn-off; else /home/ptr/bin/vpn-on; fi",
        "format-icons": ["´Ćü", "´Çú"],
        "interval": 2
    },

    "custom/proxy": {
        "format": "PRX {icon}",
        "exec": "/home/ptr/bin/proxy-waybar",
        "return-type": "json",
        "on-click": "if docker ps | grep -q redsocks-proxy; then /home/ptr/bin/proxy-off; else /home/ptr/bin/proxy-on; fi",
        "format-icons": ["´Ćü", "´Çú"],
        "interval": 2
    }
}
